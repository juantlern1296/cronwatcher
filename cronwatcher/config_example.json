{
  "webhook": {
    "url": "https://hooks.example.com/services/YOUR/WEBHOOK/URL",
    "secret": "optional-shared-secret",
    "timeout": 10
  },
  "log_level": "INFO",
  "log_file": "/var/log/cronwatcher.log",
  "check_interval": 60,
  "jobs": [
    {
      "name": "daily-backup",
      "schedule": "0 2 * * *",
      "command": "/usr/local/bin/backup.sh",
      "max_retries": 1,
      "alert_on_failure": true
    },
    {
      "name": "hourly-sync",
      "schedule": "0 * * * *",
      "command": "/usr/local/bin/sync.sh",
      "max_retries": 0,
      "alert_on_failure": true
    }
  ]
}
