{
  "webhook": {
    "url": "https://hooks.example.com/services/XXX/YYY/ZZZ",
    "secret": "optional-hmac-secret",
    "timeout_seconds": 10
  },
  "jobs": [
    {
      "name": "backup",
      "schedule": "0 2 * * *",
      "log_pattern": "/var/log/cron"
    },
    {
      "name": "cleanup",
      "schedule": "30 3 * * 0",
      "log_pattern": "/var/log/cron"
    }
  ],
  "retry": {
    "max_attempts": 3,
    "base_delay": 1.0,
    "backoff_factor": 2.0,
    "max_delay": 30.0
  },
  "cooldown_seconds": 300,
  "dedup_window_seconds": 60,
  "health_port": 8080,
  "metrics_interval_seconds": 60
}
