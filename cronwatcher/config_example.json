{
  "webhook": {
    "url": "https://hooks.example.com/services/XXX/YYY/ZZZ",
    "timeout_seconds": 5
  },
  "jobs": [
    {
      "name": "nightly-backup",
      "schedule": "0 2 * * *"
    },
    {
      "name": "hourly-sync",
      "schedule": "0 * * * *"
    }
  ],
  "job_filter": {
    "include": ["*backup*", "*sync*"],
    "exclude": ["*test*", "*dry-run*"]
  },
  "retry": {
    "max_attempts": 3,
    "base_delay_seconds": 2.0,
    "backoff_factor": 2.0
  },
  "rate_limiter": {
    "max_tokens": 10,
    "refill_rate": 1.0
  },
  "health": {
    "port": 8080
  },
  "metrics": {
    "report_interval_seconds": 60
  },
  "job_history": {
    "max_entries": 100
  }
}
